# Backend mode (dormant fallback) — used by src/lib/ApiClient + src/service/tclService.ts
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Backend-less mode (src/service/tcl/*) — non-secret TCL endpoints/app-id.
# Optional: defaults are baked into src/service/tcl/config.ts. Override only if
# TCL rotates them. Account credentials are NEVER set here — they come from the
# login form at runtime.
# NOTE: login URL needs ?clientId=54148614 (the app login client id, != appId).
NEXT_PUBLIC_TCL_APP_ID=wx6e1af3fa84fbe523
NEXT_PUBLIC_TCL_LOGIN_URL=https://pa.account.tcl.com/account/login?clientId=54148614
NEXT_PUBLIC_TCL_CLOUD_URL=https://prod-center.aws.tcljd.com/v3/global/cloud_url_get

# Same-origin proxy path served by app/api/tclproxy/route.ts. Default /api/tclproxy.
# Set empty to call TCL hosts directly (CORS-blocked in browsers — native only).
# NEXT_PUBLIC_TCL_PROXY_PATH=/api/tclproxy
